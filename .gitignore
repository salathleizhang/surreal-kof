# Player assets are generated locally by default. Keep the directory ignored,
# then allow only the currently playable runtime roster into Git.
public/assets/player/*
!public/assets/player/generated-index.json

# Playable generated fighters listed in generated-index.json.
!public/assets/player/fighter-87633c7b/
!public/assets/player/chenmian/
!public/assets/player/caixukun/
!public/assets/player/fengge-wangming-tianya/
!public/assets/player/speed/
!public/assets/player/kobe/

# Non-playable preview fighters (portrait only) listed in generated-index.json.
!public/assets/player/donald-trump/
!public/assets/player/doubao/
!public/assets/player/mark-zuckerberg/
!public/assets/player/elon-musk/
!public/assets/player/sam-altman/
!public/assets/player/dario-amodei/

# Ignore generated intermediates/previews inside whitelisted fighter folders.
public/assets/player/*/*

