{
  "name": "kof-ai",
  "version": "1.0.0",
  "description": "King of Fighters - a horizontal fighting game built with Phaser 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:music": "bash scripts/dev-chrome.sh",
    "local-api": "node --import tsx server/local-api.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "test": "node --import tsx --test test/**/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "phaser": "^3.80.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.0"
  }
}
